# PredictEdge — copy to .env and fill in your values

# Polymarket
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
POLYGON_RPC_URL=https://rpc.ankr.com/polygon

# Wallet (required for trading and claiming)
PRIVATE_KEY=<your_private_key>
WALLET_PROXY_SAFE=<your_proxy_safe_address>

# CLOB API (auto-generated from PRIVATE_KEY on startup if missing)
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# OpenAI (for AI Co-Pilot and LLM gate fallback)
OPENAI_API_KEY=
OPENAI_MODEL=openai/gpt-5-nano

# OpenRouter (optional; LLM gate for borderline cases; fallback to OpenAI if unset)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3-5-haiku
LLM_GATE_ENABLED=true
LLM_GATE_CONF_MIN=42
LLM_GATE_CONF_MAX=62

# Risk Manager
MAX_CONCURRENT_POSITIONS=4
MAX_CAPITAL_AT_RISK_PCT=20
CONSECUTIVE_LOSS_LIMIT=5
CONSECUTIVE_LOSS_PAUSE_S=1800
DRAWDOWN_LIMIT_PCT=20
ESTIMATED_BALANCE_USDC=200

# Kelly Position Sizing
KELLY_FRACTION=0.25
KELLY_MIN_MULT=0.5
KELLY_MAX_MULT=3.0

# Server
DB_PATH=predictedge.db
HOST=0.0.0.0
PORT=8888

DEMO_MODE=false
DEFAULT_ORDER_SIZE=20

# Strategy
# streak_reversal = only 6x UP/DOWN + USD momentum reversal (default)
# all             = pattern + fast_reversal + streak_reversal
# pattern         = only pattern-based auto trader
STRATEGY_MODE=streak_reversal

# Streak Reversal Trader
STREAK_REVERSAL_SIZE=100
STREAK_REVERSAL_ORDER_PRICE=0.50
STREAK_REVERSAL_LOOP_S=15
STREAK_USD_REVERSAL_THRESHOLD=200

# Fast Reversal Trader (when STRATEGY_MODE=all)
REVERSAL_USD_THRESHOLDS=BTC:200,ETH:20,SOL:2,XRP:0.10
REVERSAL_ORDER_SIZE=10
REVERSAL_ORDER_PRICE=0.40
REVERSAL_MONITOR_WINDOW_S=45
REVERSAL_ORDER_DELAY_S=0
REVERSAL_CLOB_HIGH=0.82
REVERSAL_CLOB_LOW=0.18

# Pattern Auto Trader
AUTO_TRADE_LOOP_SECONDS=30
TOP_PATTERN_COUNT=10
MIN_PATTERN_WIN_RATE_PCT=55
AUTO_CLAIM_INTERVAL_SECONDS=600
